# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# NextAuth (Admin Panel)
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# Admin credentials (stored in env — no DB needed for single admin)
ADMIN_EMAIL=admin@faisalsdentalcare.com
ADMIN_PASSWORD=change_this_strong_password

# Site URL (for SEO/OG tags)
NEXT_PUBLIC_SITE_URL=https://faisalsdentalcare.com
